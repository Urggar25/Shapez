#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if ! command -v yarn >/dev/null 2>&1; then
    echo "Erreur : yarn n'est pas installé. Installez-le puis relancez ./lancer_shapez." >&2
    exit 1
fi

if [ ! -d node_modules ]; then
    echo "Dépendances manquantes, installation avec yarn..."
    yarn install
fi

echo "Lancement de shapez (mode développement)..."
exec yarn dev "$@"
